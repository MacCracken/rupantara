# programs/smoke.cyr — compile-time proof that src/lib.cyr links clean.
# rupantara is a library — no CLI binary. Writes a banner, exits 0.

include "src/lib.cyr"

fn main(): i64 {
    alloc_init();
    var banner = "rupantara smoke: lib.cyr linked clean\n";
    syscall(1, 1, banner, strlen(banner));
    return 0;
}

var exit_code = main();
syscall(60, exit_code);
