# tests/tcyr/decode.tcyr — M2 KV-cache decode.
# The core acceptance: the cached incremental decode (ru_model_fwd_row, one token
# at a time, appending to per-layer K/V caches) reproduces the uncached full
# forward (ru_model_fwd) BIT-FOR-BIT over the same tokens. Plus a greedy-argmax
# generation smoke.
include "src/lib.cyr"
include "lib/assert.cyr"

# deterministic param fill in [-1, 1] (no PRNG dep; values just need to be varied)
fn _fill(p, n): i64 {
    var i = 0;
    while (i < n) {
        var m = (i * 37 + 11) % 101 - 50;    # -50..50
        store64(p + i * 8, f64_div(f64_from(m), f64_from(50)));
        i = i + 1;
    }
    return 0;
}

# cached decode == uncached forward, bit-for-bit, for a given config.
fn _decode_parity(V, C, T, nh, nkv, NL, F, bias, name): i64 {
    var cfg = t_alloc(8);
    ru_cfg_init(cfg, V, C, T, nh, nkv, NL, F, bias);
    var np = ru_params_count(cfg);
    var params = t_alloc(np);
    _fill(params, np);
    var tokens = t_alloc(T);
    var i = 0;
    while (i < T) { store64(tokens + i * 8, (i * 3 + 1) % V); i = i + 1; }
    # uncached: the full-window forward -> unc(T, V)
    var unc = t_alloc(T * V);
    ru_model_fwd(cfg, params, tokens, unc, 0);
    # cached: feed tokens 0..T-1 one at a time, appending K/V each step -> cache_log(T, V)
    var cache_log = t_alloc(T * V);
    var kv = t_alloc(ru_decode_kv_count(cfg));
    var row = t_alloc(V);
    var pos = 0;
    while (pos < T) {
        ru_model_fwd_row(cfg, params, load64(tokens + pos * 8), pos, kv, row);
        var v = 0;
        while (v < V) { store64(cache_log + (pos * V + v) * 8, load64(row + v * 8)); v = v + 1; }
        pos = pos + 1;
    }
    # bit-identical compare over all T*V logits
    var diffs = 0;
    i = 0;
    while (i < T * V) {
        if (load64(unc + i * 8) != load64(cache_log + i * 8)) { diffs = diffs + 1; }
        i = i + 1;
    }
    assert_eq(diffs, 0, name);
    return 0;
}

fn test_decode_parity(): i64 {
    _decode_parity(9, 8, 5, 2, 2, 2, 32, 0, "kv-decode==uncached mha-dense-nobias");
    _decode_parity(9, 8, 5, 2, 2, 2, 32, 1, "kv-decode==uncached mha-dense-bias");
    _decode_parity(7, 12, 6, 4, 2, 3, 48, 0, "kv-decode==uncached gqa-3blocks");
    _decode_parity(9, 8, 4, 4, 1, 2, 32, 0, "kv-decode==uncached mqa-nkv1");
    return 0;
}

# greedy generation smoke: seed with a token, feed argmax back each step; every
# produced id must be a valid vocab index and the decode loop must not fault.
fn test_greedy_gen(): i64 {
    var V = 9; var C = 8; var T = 6; var nh = 2; var nkv = 2; var NL = 2; var F = 32;
    var cfg = t_alloc(8);
    ru_cfg_init(cfg, V, C, T, nh, nkv, NL, F, 0);
    var np = ru_params_count(cfg);
    var params = t_alloc(np);
    _fill(params, np);
    var kv = t_alloc(ru_decode_kv_count(cfg));
    var row = t_alloc(V);
    var tok = 0;
    var pos = 0;
    var ok = 1;
    while (pos < T) {
        ru_model_fwd_row(cfg, params, tok, pos, kv, row);
        tok = ru_argmax(row, V);
        if ((tok < 0) || (tok >= V)) { ok = 0; }
        pos = pos + 1;
    }
    assert_eq(ok, 1, "greedy decode yields valid token ids");
    return 0;
}

fn main(): i64 {
    alloc_init();
    test_decode_parity();
    test_greedy_gen();
    return assert_summary();
}

var rc = main();
syscall(60, rc);
