# tests/tcyr/smoke.tcyr — rupantara scaffold smoke (M0).
include "src/lib.cyr"
include "lib/assert.cyr"

fn test_version() {
    assert_eq(rupantara_version(), 100, "version 0.1.0 packs to 100");
    return 0;
}

fn main(): i64 {
    alloc_init();
    test_version();
    return assert_summary();
}

var rc = main();
syscall(60, rc);
